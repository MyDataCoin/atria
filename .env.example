# DEV: оставь VITE_API_URL пустым — запросы идут относительным путём /api/v1/...
# через прокси Vite (см. vite.config.js), что обходит отсутствие CORS на бэкенде.
# В проде укажи полный адрес API (если фронт и API на разных доменах + настроен CORS).
VITE_API_URL=

# Адрес бэкенда, на который Vite проксирует /api в dev-режиме:
VITE_API_PROXY_TARGET=https://atria-api.eaysdev.online
